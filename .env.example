# Wix Headless — Public (safe for client bundle)
# The OAuth Client ID for your Wix Headless project.
NEXT_PUBLIC_WIX_CLIENT_ID="your-wix-client-id"

# Wix Headless — Server-side only (never expose to client)
# API Key (IST token) from Wix Dashboard → API Keys Manager.
WIX_API_KEY="your-wix-api-key"

# The Site ID for your Wix Headless project.
WIX_SITE_ID="your-wix-site-id"
